# AiSOC Environment Variables
# Copy this file to .env and fill in your values

# ─── Core Configuration ───────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aisoc:aisoc_dev_secret@localhost:5432/aisoc
REDIS_URL=redis://:redis_dev_secret@localhost:6379/0
CLICKHOUSE_URL=http://aisoc:clickhouse_dev_secret@localhost:8123/aisoc

# ─── Messaging ────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── Search ───────────────────────────────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
QDRANT_URL=http://localhost:6333

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# ─── Threat Intelligence ──────────────────────────────────────────────────────
# Open-source / community feeds (work out of the box, no key required for some)
TAXII_FEEDS=https://cti-taxii.mitre.org/taxii/,enterprise-attack,,
MISP_URL=
MISP_API_KEY=
OTX_API_KEY=
CISA_KEV_ENABLED=true
ABUSE_CH_ENABLED=true

# Free / freemium enrichment (recommended for everyone)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
GREYNOISE_API_KEY=
SHODAN_API_KEY=
URLSCAN_API_KEY=
IPINFO_API_TOKEN=

# ─── Commercial threat intelligence (optional) ────────────────────────────────
# Cyble Vision — actor, malware, vulnerability, dark-web, brand-risk feeds
# Provision a key from https://cyble.com/cyble-vision/
CYBLE_VISION_API_KEY=
CYBLE_VISION_BASE_URL=https://api.cyble.com/v2
CYBLE_VISION_TENANT_ID=
CYBLE_VISION_FEEDS=indicators,actors,vulnerabilities,leaks,brand
CYBLE_HUNT_API_KEY=

# Recorded Future
RECORDED_FUTURE_API_KEY=

# Mandiant Threat Intelligence (formerly FireEye iSIGHT)
MANDIANT_API_KEY=
MANDIANT_API_SECRET=

# Crowdstrike Falcon Intelligence (separate from the EDR connector)
CROWDSTRIKE_INTEL_CLIENT_ID=
CROWDSTRIKE_INTEL_CLIENT_SECRET=

# Anomali ThreatStream
ANOMALI_USERNAME=
ANOMALI_API_KEY=
ANOMALI_BASE_URL=https://api.threatstream.com

# IBM X-Force Exchange
XFORCE_API_KEY=
XFORCE_API_PASSWORD=

# Flashpoint
FLASHPOINT_API_KEY=

# Intel 471
INTEL471_USERNAME=
INTEL471_API_KEY=

# DomainTools Iris
DOMAINTOOLS_USERNAME=
DOMAINTOOLS_API_KEY=

# RiskIQ / Microsoft Defender External ATP
RISKIQ_USERNAME=
RISKIQ_API_KEY=

# ─── Connectors ───────────────────────────────────────────────────────────────
# CrowdStrike Falcon
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

# Splunk
SPLUNK_HOST=
SPLUNK_PORT=8089
SPLUNK_TOKEN=
SPLUNK_SCHEME=https
SPLUNK_VERIFY_SSL=true

# AWS Security Hub
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Okta
OKTA_DOMAIN=
OKTA_API_TOKEN=

# Microsoft Sentinel
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_WORKSPACE_NAME=

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

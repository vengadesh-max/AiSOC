{
  "id": "cloud-gke-anonymous-v1",
  "name": "Cloud: GKE Cluster Anonymous Auth",
  "description": "Triggered when GKE cluster is configured to allow anonymous Kubernetes API access. Disables anonymous and audits.",
  "version": "1.0.0",
  "tags": [
    "cloud-misconfig",
    "cloud",
    "gcp",
    "kubernetes",
    "mitre.t1190"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high",
      "critical"
    ],
    "tags": [
      "cloud-misconfig"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "disable-anon",
      "name": "Disable anonymous auth",
      "type": "http",
      "params": {
        "url": "${GCP_URL}/gke/{{alert.cluster}}/anonymous/disable",
        "method": "POST"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Audit anonymous-window calls",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "cloud"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Page platform team",
      "type": "notify",
      "params": {
        "channel": "pagerduty",
        "message_template": "GKE {{alert.cluster}} anonymous disabled.",
        "service_key_env": "PD_PLATFORM_KEY"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open GKE-anon ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "GKE anonymous: {{alert.cluster}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

{
  "id": "cloud-azure-blob-public-v1",
  "name": "Cloud: Azure Blob Container Public",
  "description": "Triggered when an Azure Storage container is set to public. Reverts to private and audits.",
  "version": "1.0.0",
  "tags": [
    "cloud-misconfig",
    "cloud",
    "azure",
    "storage",
    "mitre.t1530"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high"
    ],
    "tags": [
      "cloud-misconfig"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "private",
      "name": "Set container private",
      "type": "http",
      "params": {
        "url": "${AZURE_URL}/storage/{{alert.account}}/{{alert.container}}/private",
        "method": "POST"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Audit blob access",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "cloud"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify cloud team",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "Azure {{alert.container}} re-privatized.",
        "webhook_env": "SLACK_CLOUD_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open Azure ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P2",
        "title_template": "Azure blob public: {{alert.container}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

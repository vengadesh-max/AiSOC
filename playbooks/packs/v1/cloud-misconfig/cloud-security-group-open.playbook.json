{
  "id": "cloud-security-group-open-v1",
  "name": "Cloud: Security Group Opens 0.0.0.0/0",
  "description": "Triggered when a security group rule allows ingress from 0.0.0.0/0 to a sensitive port. Closes the rule and audits the change.",
  "version": "1.0.0",
  "tags": [
    "cloud-misconfig",
    "cloud",
    "aws",
    "network",
    "mitre.t1190"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high",
      "critical"
    ],
    "tags": [
      "cloud-misconfig"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "close",
      "name": "Remove 0.0.0.0/0 ingress rule",
      "type": "http",
      "params": {
        "url": "${AWS_URL}/sg/{{alert.sg}}/ingress/{{alert.rule_id}}",
        "method": "DELETE"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Audit who made the change",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "cloud"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify cloud team",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "SG {{alert.sg}} 0.0.0.0/0 ingress removed.",
        "webhook_env": "SLACK_CLOUD_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open SG ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P2",
        "title_template": "SG open: {{alert.sg}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

{
  "id": "cloud-rds-public-v1",
  "name": "Cloud: RDS Instance Publicly Accessible",
  "description": "Triggered when an RDS instance toggles to publicly accessible. Removes public access and audits.",
  "version": "1.0.0",
  "tags": [
    "cloud-misconfig",
    "cloud",
    "aws",
    "rds",
    "mitre.t1190"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high",
      "critical"
    ],
    "tags": [
      "cloud-misconfig"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "private",
      "name": "Disable RDS public access",
      "type": "http",
      "params": {
        "url": "${AWS_URL}/rds/{{alert.instance}}/public/disable",
        "method": "POST"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Audit RDS access window",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "cloud"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify cloud team",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "RDS {{alert.instance}} no longer public.",
        "webhook_env": "SLACK_CLOUD_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open RDS-public ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "RDS public: {{alert.instance}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

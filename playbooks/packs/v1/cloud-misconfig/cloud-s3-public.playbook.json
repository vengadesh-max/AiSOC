{
  "id": "cloud-s3-public-v1",
  "name": "Cloud: S3 Bucket Public \u2014 Re-private & Audit",
  "description": "Triggered by `s3-public-bucket` detection. Sets bucket private, enables Block Public Access, and audits last 7d access logs.",
  "version": "1.0.0",
  "tags": [
    "cloud-misconfig",
    "cloud",
    "aws",
    "s3",
    "mitre.t1530"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high",
      "critical"
    ],
    "tags": [
      "cloud-misconfig"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "private",
      "name": "Set bucket private",
      "type": "http",
      "params": {
        "url": "${AWS_URL}/s3/{{alert.bucket}}/acl/private",
        "method": "PUT"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "bpa",
      "name": "Enable Block Public Access",
      "type": "http",
      "params": {
        "url": "${AWS_URL}/s3/{{alert.bucket}}/block-public-access",
        "method": "PUT"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Audit last 7d S3 access",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "cloud"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify cloud team",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "S3 {{alert.bucket}} re-privatized.",
        "webhook_env": "SLACK_CLOUD_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open cloud ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P2",
        "title_template": "S3 public: {{alert.bucket}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

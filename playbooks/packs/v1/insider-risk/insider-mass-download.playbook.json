{
  "id": "insider-mass-download-v1",
  "name": "Insider: Mass File Download",
  "description": "Triggered when a single user downloads >N files from a sensitive store in <T window. Reduces user permissions and notifies manager.",
  "version": "1.0.0",
  "tags": [
    "insider-risk",
    "insider",
    "dlp",
    "mitre.t1530"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high"
    ],
    "tags": [
      "insider-risk"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "e1",
      "name": "Enrich user role + tenure",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.user"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "readonly",
      "name": "Set sensitive-store ACL to read-only",
      "type": "http",
      "params": {
        "url": "${SAAS_URL}/acl/{{alert.user}}/readonly",
        "method": "POST"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate access pattern",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "identity"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify user's manager",
      "type": "notify",
      "params": {
        "channel": "email",
        "message_template": "High-volume download by {{alert.user}}. Review needed.",
        "webhook_env": "EMAIL_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open insider-risk ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P3",
        "title_template": "Mass download: {{alert.user}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

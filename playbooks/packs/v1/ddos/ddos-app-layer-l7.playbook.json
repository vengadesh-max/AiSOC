{
  "id": "ddos-app-layer-l7-v1",
  "name": "DDoS: Application Layer L7",
  "description": "Triggered by anomalous L7 request rate or pattern. Engages WAF rate-limit rule and challenge-page.",
  "version": "1.0.0",
  "tags": [
    "ddos",
    "ddos",
    "waf",
    "mitre.t1498.001"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high",
      "critical"
    ],
    "tags": [
      "ddos"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "waf-rl",
      "name": "Apply WAF rate-limit",
      "type": "http",
      "params": {
        "url": "${WAF_URL}/rate-limit",
        "method": "POST",
        "body_template": "{\"target\":\"{{alert.target}}\",\"rps\":{{alert.threshold_rps}}}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "challenge",
      "name": "Enable challenge page",
      "type": "http",
      "params": {
        "url": "${WAF_URL}/challenge/enable",
        "method": "POST",
        "body_template": "{\"target\":\"{{alert.target}}\"}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate L7 signature",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "forensics"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify SOC + platform",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "L7 DDoS on {{alert.target}}. WAF rate-limit + challenge on.",
        "webhook_env": "SLACK_SOC_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open L7 DDoS ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P2",
        "title_template": "L7 DDoS: {{alert.target}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

{
  "id": "ddos-syn-flood-v1",
  "name": "DDoS: SYN Flood",
  "description": "Triggered by SYN flood pattern at edge. Enables SYN cookies and increases backend capacity.",
  "version": "1.0.0",
  "tags": [
    "ddos",
    "ddos",
    "network",
    "mitre.t1498"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high",
      "critical"
    ],
    "tags": [
      "ddos"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "syn-cookies",
      "name": "Enable SYN cookies at edge",
      "type": "http",
      "params": {
        "url": "${EDGE_URL}/syn-cookies/enable",
        "method": "POST"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "scale",
      "name": "Scale backend capacity",
      "type": "http",
      "params": {
        "url": "${PLATFORM_URL}/scale",
        "method": "POST",
        "body_template": "{\"target\":\"{{alert.target}}\",\"replicas\":\"+50%\"}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate flood",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "forensics"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify network on-call",
      "type": "notify",
      "params": {
        "channel": "pagerduty",
        "message_template": "SYN flood on {{alert.target}}. SYN cookies + scale-out.",
        "service_key_env": "PD_NETWORK_KEY"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open SYN-flood ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "SYN flood: {{alert.target}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

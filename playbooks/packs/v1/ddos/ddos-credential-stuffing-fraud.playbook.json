{
  "id": "ddos-credential-stuffing-fraud-v1",
  "name": "DDoS: Auth-Endpoint Credential Stuffing",
  "description": "Triggered when /login takes a sustained spike of failed attempts. Combines DDoS + credential-stuffing response: WAF challenge, rate-limit, source-IP block.",
  "version": "1.0.0",
  "tags": [
    "ddos",
    "ddos",
    "ato",
    "mitre.t1110.004"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high"
    ],
    "tags": [
      "ddos"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "challenge",
      "name": "Enable WAF challenge on /login",
      "type": "http",
      "params": {
        "url": "${WAF_URL}/challenge/enable",
        "method": "POST",
        "body_template": "{\"path\":\"/login\"}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "rate-limit",
      "name": "Apply per-IP rate-limit",
      "type": "http",
      "params": {
        "url": "${WAF_URL}/rate-limit",
        "method": "POST",
        "body_template": "{\"path\":\"/login\",\"per\":\"ip\",\"rps\":5}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "b1",
      "name": "Block top abusers",
      "type": "block_ip",
      "params": {
        "ip_field": "alert.top_abuser_ip",
        "duration": "24h"
      },
      "on_failure": "abort",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate cred-stuffing campaign",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "identity"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify SOC",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "Auth-endpoint credential stuffing on /login mitigated.",
        "webhook_env": "SLACK_SOC_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open auth-DDoS ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P2",
        "title_template": "Auth DDoS: {{alert.target}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

{
  "id": "ato-credential-stuffing-v1",
  "name": "ATO: Credential Stuffing \u2014 Block & Reset",
  "description": "Triggered by high-volume failed logins from a single source. Blocks the IP range, identifies impacted users, and forces resets.",
  "version": "1.0.0",
  "tags": [
    "account-takeover",
    "ato",
    "identity",
    "mitre.t1110.004"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high",
      "critical"
    ],
    "tags": [
      "account-takeover"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "e1",
      "name": "Enrich source IP reputation",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.source_ip"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "b1",
      "name": "Block source IP",
      "type": "block_ip",
      "params": {
        "ip_field": "alert.source_ip",
        "duration": "48h"
      },
      "on_failure": "abort",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "list",
      "name": "List impacted users",
      "type": "http",
      "params": {
        "url": "${SIEM_URL}/search/credential_stuffing/{{alert.source_ip}}",
        "method": "GET"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate cred-stuffing campaign",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "identity"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "reset-all",
      "name": "Force reset for impacted users",
      "type": "http",
      "params": {
        "url": "${IDP_BASE_URL}/bulk/password-reset",
        "method": "POST",
        "body_template": "{\"user_ids\": {{context.impacted_user_ids}}}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "n1",
      "name": "Page identity team",
      "type": "notify",
      "params": {
        "channel": "pagerduty",
        "message_template": "Credential stuffing from {{alert.source_ip}}: {{context.impacted_user_count}} users reset.",
        "service_key_env": "PD_IDENTITY_KEY"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open ATO ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "Credential stuffing: {{alert.source_ip}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

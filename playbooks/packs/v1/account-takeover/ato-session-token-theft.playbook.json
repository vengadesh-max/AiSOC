{
  "id": "ato-session-token-theft-v1",
  "name": "ATO: Session Token Theft \u2014 Revoke & Isolate",
  "description": "Triggered when an authenticated session is observed from a new device + new geo simultaneously. Revokes all tokens and isolates the originating endpoint if known.",
  "version": "1.0.0",
  "tags": [
    "account-takeover",
    "ato",
    "identity",
    "session-hijack",
    "mitre.t1539"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "critical"
    ],
    "tags": [
      "account-takeover"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "e1",
      "name": "Enrich session context",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.session_id"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "revoke",
      "name": "Revoke all sessions for user",
      "type": "http",
      "params": {
        "url": "${IDP_BASE_URL}/users/{{alert.user}}/sessions/revoke-all",
        "method": "POST"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate token-theft chain",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "forensics"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "iso",
      "name": "Isolate originating endpoint",
      "type": "isolate_host",
      "params": {
        "host_field": "alert.host"
      },
      "on_failure": "abort",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "n1",
      "name": "Page on-call",
      "type": "notify",
      "params": {
        "channel": "pagerduty",
        "message_template": "Session theft suspected for {{alert.user}}. Tokens revoked, host {{alert.host}} isolated.",
        "service_key_env": "PD_SOC_KEY"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open P1 ATO ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "Session token theft: {{alert.user}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

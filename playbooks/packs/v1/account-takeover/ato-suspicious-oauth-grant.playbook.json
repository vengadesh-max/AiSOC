{
  "id": "ato-suspicious-oauth-grant-v1",
  "name": "ATO: Suspicious OAuth Grant \u2014 Revoke & Investigate",
  "description": "Triggered when a user grants a new OAuth scope to an unfamiliar third-party app. Revokes the grant and investigates.",
  "version": "1.0.0",
  "tags": [
    "account-takeover",
    "ato",
    "identity",
    "oauth",
    "mitre.t1528"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "medium",
      "high"
    ],
    "tags": [
      "account-takeover"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "e1",
      "name": "Enrich OAuth client reputation",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.oauth_client_id"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "inv",
      "name": "Investigate scope and lineage",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "identity"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "revoke",
      "name": "Revoke OAuth grant",
      "type": "http",
      "params": {
        "url": "${IDP_BASE_URL}/users/{{alert.user}}/oauth/{{alert.oauth_client_id}}",
        "method": "DELETE"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "n1",
      "name": "Notify user",
      "type": "notify",
      "params": {
        "channel": "email",
        "message_template": "Removed OAuth grant for {{alert.oauth_client_app_name}}. Re-add only if intentional.",
        "webhook_env": "EMAIL_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open OAuth-abuse ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P3",
        "title_template": "Suspicious OAuth grant: {{alert.user}} -> {{alert.oauth_client_app_name}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

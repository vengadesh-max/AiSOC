{
  "id": "lateral-rdp-spray-v1",
  "name": "Lateral: RDP Spray",
  "description": "Triggered when one host opens RDP to >N hosts in <T window. Blocks the source IP, isolates host, investigates.",
  "version": "1.0.0",
  "tags": [
    "lateral-movement",
    "lateral",
    "rdp",
    "mitre.t1021.001"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high"
    ],
    "tags": [
      "lateral-movement"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "b1",
      "name": "Block source IP",
      "type": "block_ip",
      "params": {
        "ip_field": "alert.src_ip",
        "duration": "24h"
      },
      "on_failure": "abort",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "iso",
      "name": "Isolate source host",
      "type": "isolate_host",
      "params": {
        "host_field": "alert.src_host"
      },
      "on_failure": "abort",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "inv",
      "name": "Investigate RDP spray",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "forensics"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify SOC",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "RDP spray from {{alert.src_host}} blocked.",
        "webhook_env": "SLACK_SOC_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open RDP-spray ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P2",
        "title_template": "RDP spray: {{alert.src_host}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

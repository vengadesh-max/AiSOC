{
  "id": "exfil-archive-egress-v1",
  "name": "Exfil: Archive File Egress (.zip / .7z / .rar)",
  "description": "Triggered when a host uploads an archive to an external dest. Holds the file in DLP review queue and notifies user's manager.",
  "version": "1.0.0",
  "tags": [
    "data-exfil",
    "exfil",
    "dlp",
    "archive"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "medium",
      "high"
    ],
    "tags": [
      "data-exfil"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "e1",
      "name": "Enrich destination",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.dst_host"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "dlp-review",
      "name": "Send to DLP review queue",
      "type": "http",
      "params": {
        "url": "${DLP_URL}/review",
        "method": "POST",
        "body_template": "{\"host\":\"{{alert.host}}\",\"file\":\"{{alert.file_name}}\",\"dst\":\"{{alert.dst_host}}\"}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate archive content",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "forensics"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify user's manager",
      "type": "notify",
      "params": {
        "channel": "email",
        "message_template": "Archive upload by {{alert.user}} to {{alert.dst_host}} queued for DLP review.",
        "webhook_env": "EMAIL_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open DLP ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P3",
        "title_template": "Archive egress: {{alert.user}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

{
  "id": "exfil-personal-cloud-v1",
  "name": "Exfil: Personal Cloud Storage Upload",
  "description": "Triggered when corporate data uploads to a personal cloud (personal Drive, Dropbox, iCloud). Blocks dest, manager notify.",
  "version": "1.0.0",
  "tags": [
    "data-exfil",
    "exfil",
    "saas",
    "mitre.t1567.002"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "medium",
      "high"
    ],
    "tags": [
      "data-exfil"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "block",
      "name": "Block destination at proxy",
      "type": "http",
      "params": {
        "url": "${PROXY_URL}/policy/block",
        "method": "POST",
        "body_template": "{\"host\":\"{{alert.dst_host}}\",\"reason\":\"personal-cloud\"}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate access pattern",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "identity"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify user's manager",
      "type": "notify",
      "params": {
        "channel": "email",
        "message_template": "Personal-cloud upload by {{alert.user}} to {{alert.dst_host}} blocked.",
        "webhook_env": "EMAIL_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open exfil ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P3",
        "title_template": "Personal cloud: {{alert.user}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

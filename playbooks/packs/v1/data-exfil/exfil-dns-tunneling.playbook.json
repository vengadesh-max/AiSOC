{
  "id": "exfil-dns-tunneling-v1",
  "name": "Exfil: DNS Tunneling",
  "description": "Triggered by high-entropy DNS query length on a host. Sinkholes the suspect domain and isolates the host.",
  "version": "1.0.0",
  "tags": [
    "data-exfil",
    "exfil",
    "dns",
    "mitre.t1071.004"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "critical"
    ],
    "tags": [
      "data-exfil"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "e1",
      "name": "Enrich domain reputation",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.dns_query"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "sinkhole",
      "name": "Sinkhole domain at resolver",
      "type": "http",
      "params": {
        "url": "${DNS_URL}/sinkhole",
        "method": "POST",
        "body_template": "{\"domain\":\"{{alert.dns_query}}\"}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "iso",
      "name": "Isolate beaconing host",
      "type": "isolate_host",
      "params": {
        "host_field": "alert.host"
      },
      "on_failure": "abort",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "inv",
      "name": "Investigate DNS tunneling",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "forensics"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Page on-call",
      "type": "notify",
      "params": {
        "channel": "pagerduty",
        "message_template": "DNS tunneling {{alert.host}} -> {{alert.dns_query}} sinkholed and isolated.",
        "service_key_env": "PD_SOC_KEY"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open DNS-tunnel ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "DNS tunneling: {{alert.host}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

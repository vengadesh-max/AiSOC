{
  "id": "ransomware-shadow-copy-deletion-v1",
  "name": "Ransomware: Shadow Copy Deletion Detected",
  "description": "Triggered on `vssadmin delete shadows` or wmic shadowcopy delete. Pre-encryption signal \u2014 isolate fast and verify backups.",
  "version": "1.0.0",
  "tags": [
    "ransomware",
    "ransomware",
    "endpoint",
    "mitre.t1490"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "critical"
    ],
    "tags": [
      "ransomware"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "iso",
      "name": "Isolate host (EDR)",
      "type": "isolate_host",
      "params": {
        "host_field": "alert.host"
      },
      "on_failure": "abort",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "verify-backup",
      "name": "Verify last successful backup",
      "type": "http",
      "params": {
        "url": "${BACKUP_URL}/hosts/{{alert.host}}/last-backup",
        "method": "GET"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Forensic investigation",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "forensics"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify backup team",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "Shadow-copy deletion on {{alert.host}}. Last backup: {{context.last_backup_at}}.",
        "webhook_env": "SLACK_BACKUP_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open ransomware ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "Shadow copies deleted: {{alert.host}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

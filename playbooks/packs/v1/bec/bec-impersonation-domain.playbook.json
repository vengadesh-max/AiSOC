{
  "id": "bec-impersonation-domain-v1",
  "name": "BEC: Impersonation Domain Quarantine",
  "description": "Triggered when an inbound email originates from a domain that look-alikes an executive or vendor. Quarantines and blocks.",
  "version": "1.0.0",
  "tags": [
    "bec",
    "bec",
    "email",
    "mitre.t1656"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high"
    ],
    "tags": [
      "bec"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "e1",
      "name": "Enrich sender domain",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.sender_domain"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "quarantine",
      "name": "Quarantine impersonation message",
      "type": "http",
      "params": {
        "url": "${MAIL_URL}/messages/{{alert.message_id}}/quarantine",
        "method": "POST"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "block-domain",
      "name": "Block sender domain",
      "type": "http",
      "params": {
        "url": "${MAIL_URL}/policy/block-domain",
        "method": "POST",
        "body_template": "{\"domain\":\"{{alert.sender_domain}}\"}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate BEC campaign",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "identity"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify SOC",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "Impersonation domain {{alert.sender_domain}} blocked.",
        "webhook_env": "SLACK_SOC_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open BEC ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P3",
        "title_template": "BEC impersonation: {{alert.sender_domain}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

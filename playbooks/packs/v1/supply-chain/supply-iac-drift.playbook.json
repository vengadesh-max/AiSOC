{
  "id": "supply-iac-drift-v1",
  "name": "Supply Chain: IaC Drift Detected",
  "description": "Triggered when production infra deviates from IaC source of truth in a security-relevant way. Reverts to declared state.",
  "version": "1.0.0",
  "tags": [
    "supply-chain",
    "supply-chain",
    "iac",
    "drift"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "medium",
      "high"
    ],
    "tags": [
      "supply-chain"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "revert",
      "name": "Revert to declared IaC state",
      "type": "http",
      "params": {
        "url": "${IAC_URL}/apply",
        "method": "POST",
        "body_template": "{\"resource\":\"{{alert.resource_id}}\"}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate drift cause",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "cloud"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify platform team",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "IaC drift {{alert.resource_id}} reverted.",
        "webhook_env": "SLACK_PLATFORM_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open IaC-drift ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P3",
        "title_template": "IaC drift: {{alert.resource_id}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

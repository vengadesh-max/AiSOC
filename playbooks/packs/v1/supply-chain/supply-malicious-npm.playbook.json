{
  "id": "supply-malicious-npm-v1",
  "name": "Supply Chain: Malicious npm Package",
  "description": "Triggered when a published npm package matches a known-bad list. Blocks installs at registry-mirror, audits org installs.",
  "version": "1.0.0",
  "tags": [
    "supply-chain",
    "supply-chain",
    "npm",
    "mitre.t1195"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high",
      "critical"
    ],
    "tags": [
      "supply-chain"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "e1",
      "name": "Enrich package reputation",
      "type": "enrich",
      "params": {
        "indicator_field": "alert.package_name"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 30
    },
    {
      "id": "block",
      "name": "Add package to mirror block-list",
      "type": "http",
      "params": {
        "url": "${REGISTRY_URL}/policy/block",
        "method": "POST",
        "body_template": "{\"ecosystem\":\"npm\",\"package\":\"{{alert.package_name}}\",\"version\":\"{{alert.package_version}}\"}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "audit-installs",
      "name": "List org installs",
      "type": "http",
      "params": {
        "url": "${SCA_URL}/installs?ecosystem=npm&package={{alert.package_name}}",
        "method": "GET"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate supply-chain blast radius",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "cloud"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Page eng-sec",
      "type": "notify",
      "params": {
        "channel": "pagerduty",
        "message_template": "Malicious npm {{alert.package_name}} blocked. {{context.install_count}} installs found.",
        "service_key_env": "PD_ENGSEC_KEY"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open supply-chain ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "Malicious npm: {{alert.package_name}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

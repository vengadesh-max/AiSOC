{
  "id": "supply-vendor-breach-v1",
  "name": "Supply Chain: Vendor Breach Notification",
  "description": "Triggered when a vendor publishes a breach advisory matching internal vendor inventory. Blocks vendor IPs, opens procurement review.",
  "version": "1.0.0",
  "tags": [
    "supply-chain",
    "supply-chain",
    "vendor",
    "mitre.t1199"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high",
      "critical"
    ],
    "tags": [
      "supply-chain"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "block-vendor-ips",
      "name": "Block vendor IP ranges",
      "type": "http",
      "params": {
        "url": "${FW_URL}/policy/block-vendor",
        "method": "POST",
        "body_template": "{\"vendor\":\"{{alert.vendor}}\"}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate vendor exposure",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "cloud"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Notify procurement + sec",
      "type": "notify",
      "params": {
        "channel": "slack",
        "message_template": "Vendor {{alert.vendor}} breach. IPs blocked. Review contracts and integrations.",
        "webhook_env": "SLACK_PROCUREMENT_WEBHOOK"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open vendor-breach ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "Vendor breach: {{alert.vendor}}",
        "queue": "procurement"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

{
  "id": "supply-github-action-compromise-v1",
  "name": "Supply Chain: GitHub Action Compromise",
  "description": "Triggered when a referenced GitHub Action SHA changes unexpectedly or matches a compromise advisory. Pin to last-known-good and audit.",
  "version": "1.0.0",
  "tags": [
    "supply-chain",
    "supply-chain",
    "github",
    "mitre.t1195.002"
  ],
  "trigger": {
    "on": "alert",
    "severity": [
      "high",
      "critical"
    ],
    "tags": [
      "supply-chain"
    ]
  },
  "author": "AiSOC",
  "enabled": true,
  "created_at": "2026-05-03T00:00:00+00:00",
  "updated_at": "2026-05-03T00:00:00+00:00",
  "steps": [
    {
      "id": "pin",
      "name": "Pin Action to last-known-good SHA",
      "type": "http",
      "params": {
        "url": "${CI_URL}/actions/pin",
        "method": "POST",
        "body_template": "{\"action\":\"{{alert.action}}\",\"sha\":\"{{alert.lkg_sha}}\"}"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "audit",
      "name": "List workflows using this Action",
      "type": "http",
      "params": {
        "url": "${CI_URL}/workflows?action={{alert.action}}",
        "method": "GET"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    },
    {
      "id": "inv",
      "name": "Investigate Action compromise",
      "type": "investigate",
      "params": {
        "case_id_field": "alert.case_id",
        "focus": "cloud"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 180
    },
    {
      "id": "n1",
      "name": "Page eng-sec",
      "type": "notify",
      "params": {
        "channel": "pagerduty",
        "message_template": "GH Action {{alert.action}} pinned to {{alert.lkg_sha}}.",
        "service_key_env": "PD_ENGSEC_KEY"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 10
    },
    {
      "id": "t1",
      "name": "Open Action-compromise ticket",
      "type": "create_ticket",
      "params": {
        "priority": "P1",
        "title_template": "GH Action compromise: {{alert.action}}",
        "queue": "soc"
      },
      "on_failure": "continue",
      "retry_max": 0,
      "timeout_seconds": 20
    }
  ]
}

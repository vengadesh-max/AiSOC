{
  "name": "aisoc",
  "version": "1.0.0",
  "private": true,
  "description": "AiSOC - AI-powered Security Operations Center by Cyble",
  "license": "MIT",
  "author": "Cyble Inc.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "infra:plan": "cd infra/terraform && terraform plan",
    "infra:apply": "cd infra/terraform && terraform apply",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "seed:demo": "docker compose -f docker-compose.dev.yml exec api python -m app.scripts.seed_demo",
    "demo:produce": "go run ./services/demo-producer",
    "demo:produce:fast": "go run ./services/demo-producer --rate 8 --batch 10",
    "detections:validate": "python3 scripts/validate_detections.py",
    "marketplace:sync": "cp marketplace/index.json apps/web/public/marketplace/index.json && echo 'marketplace/index.json synced to apps/web/public/'",
    "aisoc:lab": "bash scripts/lab.sh"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.4",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.1"
}
